#!/usr/bin/env node

/**
 * bin/zed — ZED Knowledge Engine CLI
 *
 * Token-efficient CLI interface. Claude calls this via Bash instead of
 * loading 20+ MCP tool schemas into every message.
 *
 * Usage: zed <command> [args...] [--json]
 */

'use strict';

const path = require('path');
const fs = require('fs');

// ---------------------------------------------------------------------------
// Configuration (matches MCP server paths)
// ---------------------------------------------------------------------------

const DATA_DIR = process.env.ZED_DATA_DIR || process.env.CLAUDE_PLUGIN_DATA || path.join(process.env.HOME, '.zed-data');
const VAULT_DIR = path.join(DATA_DIR, 'vault');
const DB_PATH = path.join(DATA_DIR, 'knowledge.db');
const GLOBAL_DIR = path.join(process.env.HOME, '.zed', 'global');
const GLOBAL_DB_PATH = path.join(process.env.HOME, '.zed', 'global.db');

// Ensure dirs exist
for (const dir of [
  VAULT_DIR,
  path.join(VAULT_DIR, 'decisions'),
  path.join(VAULT_DIR, 'patterns'),
  path.join(VAULT_DIR, 'sessions'),
  path.join(VAULT_DIR, 'architecture'),
  GLOBAL_DIR,
  path.join(GLOBAL_DIR, 'patterns'),
  path.join(GLOBAL_DIR, 'learnings'),
  path.join(VAULT_DIR, '_loop'),
]) {
  if (!fs.existsSync(dir)) fs.mkdirSync(dir, { recursive: true });
}

// ---------------------------------------------------------------------------
// Parse args
// ---------------------------------------------------------------------------

const args = process.argv.slice(2);
const jsonMode = args.includes('--json');
const filteredArgs = args.filter(a => a !== '--json');
const command = filteredArgs[0];
const commandArgs = filteredArgs.slice(1);

if (!command || command === 'help' || command === '--help') {
  printHelp();
  process.exit(0);
}

// ---------------------------------------------------------------------------
// Initialize engine (lazy — only when needed)
// ---------------------------------------------------------------------------

let _engine = null;
let _globalEngine = null;

function getEngine() {
  if (!_engine) {
    try {
      const KnowledgeEngine = require('../core/engine.cjs');
      _engine = new KnowledgeEngine({ vaultPath: VAULT_DIR, dbPath: DB_PATH });
      _engine.build();
    } catch (err) {
      if (err.code === 'MODULE_NOT_FOUND') {
        console.error('Error: ZED engine not installed. Run: npm install');
      } else {
        console.error(`Error: Could not initialize vault at ${VAULT_DIR}`);
        console.error(`  ${err.message}`);
        console.error('\nTry: zed rebuild — or check that the vault directory is accessible.');
      }
      process.exit(1);
    }
  }
  return _engine;
}

function getGlobalEngine() {
  if (!_globalEngine) {
    try {
      const KnowledgeEngine = require('../core/engine.cjs');
      _globalEngine = new KnowledgeEngine({ vaultPath: GLOBAL_DIR, dbPath: GLOBAL_DB_PATH });
      _globalEngine.build();
    } catch (err) {
      console.error(`Error: Could not initialize global vault at ${GLOBAL_DIR}`);
      console.error(`  ${err.message}`);
      process.exit(1);
    }
  }
  return _globalEngine;
}

// ---------------------------------------------------------------------------
// Output helpers
// ---------------------------------------------------------------------------

function output(data) {
  if (jsonMode) {
    console.log(JSON.stringify(data, null, 2));
  } else if (typeof data === 'string') {
    console.log(data);
  } else {
    console.log(JSON.stringify(data, null, 2));
  }
}

function error(msg) {
  if (jsonMode) {
    console.error(JSON.stringify({ error: msg }));
  } else {
    console.error(`Error: ${msg}`);
  }
  process.exit(1);
}

// ---------------------------------------------------------------------------
// Health score computation (shared by health + overview commands)
// ---------------------------------------------------------------------------

function computeHealthScore(stats, clusterCount, hubsWithLinks) {
  if (stats.nodeCount === 0) return { score: 0, grade: 'N/A', connectivityRatio: 0, orphanRatio: 0 };
  const connectivityRatio = stats.edgeCount / stats.nodeCount;
  const orphanRatio = stats.orphanCount / stats.nodeCount;

  let score = 50;
  score += Math.min(20, connectivityRatio * 10);
  score -= Math.min(20, orphanRatio * 30);
  score += Math.min(15, hubsWithLinks * 3);
  const clusterPenalty = clusterCount > 1 ? Math.min(15, (clusterCount - 1) * 2) : 0;
  score += 15 - clusterPenalty;
  score = Math.max(0, Math.min(100, Math.round(score)));

  let grade;
  if (score >= 90) grade = 'A';
  else if (score >= 75) grade = 'B';
  else if (score >= 60) grade = 'C';
  else if (score >= 40) grade = 'D';
  else grade = 'F';

  return { score, grade, connectivityRatio, orphanRatio };
}

// ---------------------------------------------------------------------------
// Note path resolution (same logic as MCP server)
// ---------------------------------------------------------------------------

function resolveNotePath(input) {
  const resolvedVault = path.resolve(VAULT_DIR);
  const resolvedGlobal = path.resolve(GLOBAL_DIR);

  // Helper: check if a path is within the vault or global dir
  function isInsideAllowedDir(p) {
    const resolved = path.resolve(p);
    return (resolved.startsWith(resolvedVault + path.sep) || resolved === resolvedVault) ||
           (resolved.startsWith(resolvedGlobal + path.sep) || resolved === resolvedGlobal);
  }

  if (path.isAbsolute(input) && fs.existsSync(input)) {
    if (!isInsideAllowedDir(input)) return null; // Path traversal: outside allowed dirs
    return input;
  }
  const vaultRelative = path.join(VAULT_DIR, input);
  if (!isInsideAllowedDir(vaultRelative)) return null; // Path traversal: escapes vault
  if (fs.existsSync(vaultRelative)) return vaultRelative;
  if (!input.endsWith('.md')) {
    const withExt = path.join(VAULT_DIR, input + '.md');
    if (isInsideAllowedDir(withExt) && fs.existsSync(withExt)) return withExt;
  }
  const engine = getEngine();
  const notes = engine.listNotes();
  for (const notePath of notes) {
    const basename = path.basename(notePath, '.md');
    if (basename.toLowerCase() === input.toLowerCase()) return notePath;
    try {
      const note = engine.readNote(notePath);
      if (note.title && note.title.toLowerCase() === input.toLowerCase()) return notePath;
    } catch { continue; }
  }
  return null;
}

function formatTimeAgo(ms) {
  const seconds = Math.floor(ms / 1000);
  if (seconds < 60) return 'just now';
  const minutes = Math.floor(seconds / 60);
  if (minutes < 60) return `${minutes}m ago`;
  const hours = Math.floor(minutes / 60);
  if (hours < 24) return `${hours}h ago`;
  const days = Math.floor(hours / 24);
  if (days < 7) return `${days}d ago`;
  return `${Math.floor(days / 7)}w ago`;
}

// ---------------------------------------------------------------------------
// Commands
// ---------------------------------------------------------------------------

const commands = {

  version() {
    const pkg = require('../package.json');
    output(jsonMode ? { name: pkg.name, version: pkg.version } : `zed v${pkg.version}`);
  },

  // --- Graph queries ---

  backlinks() {
    const notePath = commandArgs[0];
    if (!notePath) error('Usage: zed backlinks <note>');
    const resolved = resolveNotePath(notePath);
    if (!resolved) error(`Note not found: ${notePath}`);
    const engine = getEngine();
    const backlinks = engine.getBacklinks(resolved);
    if (jsonMode) return output({ note: path.basename(resolved), backlinks });
    if (backlinks.length === 0) return output(`No backlinks for "${path.basename(resolved)}"`);
    const lines = backlinks.map(b => `  ${b.source_title} → "${b.link_text}"`);
    output(`Backlinks to ${path.basename(resolved)}:\n${lines.join('\n')}`);
  },

  related() {
    const notePath = commandArgs[0];
    const maxHops = parseInt(commandArgs[1]) || 2;
    if (!notePath) error('Usage: zed related <note> [hops]');
    const resolved = resolveNotePath(notePath);
    if (!resolved) error(`Note not found: ${notePath}`);
    const engine = getEngine();
    const related = engine.getRelated(resolved, maxHops);
    if (jsonMode) return output({ note: path.basename(resolved), maxHops, related });
    if (related.length === 0) return output(`No related notes within ${maxHops} hops`);
    const lines = related.map(r => `  ${r.node.title} (${r.distance} hop${r.distance > 1 ? 's' : ''})`);
    output(`Related to ${path.basename(resolved)} (${maxHops} hops):\n${lines.join('\n')}`);
  },

  hubs() {
    const limit = parseInt(commandArgs[0]) || 10;
    const engine = getEngine();
    const hubs = engine.findHubs(limit);
    if (jsonMode) return output({ hubs });
    if (hubs.length === 0) return output('No hubs (empty graph)');
    const lines = hubs.map((h, i) => `  ${i + 1}. ${h.title} — ${h.backlink_count} backlinks`);
    output(`Knowledge Hubs:\n${lines.join('\n')}`);
  },

  clusters() {
    const engine = getEngine();
    const clusters = engine.getClusters();
    if (jsonMode) return output({ clusters: clusters.map((c, i) => ({ id: i + 1, size: c.length, members: c.map(n => n.title) })) });
    if (clusters.length === 0) return output('No clusters (empty graph)');
    const lines = clusters.map((c, i) => `  Cluster ${i + 1} (${c.length} notes): ${c.map(n => n.title).join(', ')}`);
    output(`Knowledge Clusters:\n${lines.join('\n')}`);
  },

  path() {
    const from = commandArgs[0];
    const to = commandArgs[1];
    if (!from || !to) error('Usage: zed path <from> <to>');
    const fromResolved = resolveNotePath(from);
    const toResolved = resolveNotePath(to);
    if (!fromResolved) error(`Source not found: ${from}`);
    if (!toResolved) error(`Target not found: ${to}`);
    const engine = getEngine();
    const sp = engine.shortestPath(fromResolved, toResolved);
    if (jsonMode) return output({ from, to, path: sp ? sp.map(n => n.title) : null });
    if (!sp) return output(`No path between "${from}" and "${to}"`);
    output(`Path: ${sp.map(n => n.title).join(' → ')} (${sp.length - 1} hops)`);
  },

  // --- Vault info ---

  stats() {
    const engine = getEngine();
    const stats = engine.getStats();
    if (jsonMode) return output({ ...stats, vaultPath: VAULT_DIR, dbPath: DB_PATH });
    output(`Notes: ${stats.nodeCount}  Connections: ${stats.edgeCount}  Orphans: ${stats.orphanCount}  Clusters: ${stats.clusterCount}`);
  },

  health() {
    const engine = getEngine();
    const stats = engine.getStats();
    const hubs = engine.findHubs(100);
    const orphans = engine.getOrphans();
    const clusters = engine.getClusters();

    if (stats.nodeCount === 0) {
      return output(jsonMode ? { score: 0, grade: 'N/A', message: 'Empty vault' } : 'Vault Health: Empty — no notes yet');
    }

    const hubsWithLinks = hubs.filter(h => h.backlink_count > 0).length;
    const avgBacklinks = hubs.length > 0 ? hubs.reduce((sum, h) => sum + h.backlink_count, 0) / hubs.length : 0;

    const { score, grade, connectivityRatio, orphanRatio } = computeHealthScore(stats, clusters.length, hubsWithLinks);

    const recs = [];
    if (orphanRatio > 0.3) recs.push('Connect orphan notes');
    if (connectivityRatio < 1) recs.push('Add more [[wikilinks]]');
    if (clusters.length > 3) recs.push(`Bridge ${clusters.length} disconnected clusters`);
    if (stats.nodeCount < 10) recs.push('Keep adding knowledge');

    if (jsonMode) return output({ score, grade, stats, orphanRatio, connectivityRatio, avgBacklinks, recommendations: recs });
    const lines = [
      `Vault Health: ${grade} (${score}/100)`,
      `  Notes: ${stats.nodeCount}  Connections: ${stats.edgeCount}  Orphans: ${stats.orphanCount}`,
    ];
    if (recs.length > 0) lines.push(`  Recommendations: ${recs.join('; ')}`);
    output(lines.join('\n'));
  },

  tags() {
    const engine = getEngine();
    const filterTag = commandArgs[0];

    if (filterTag) {
      const results = engine.searchByTag(filterTag, { limit: 50 });
      if (jsonMode) return output({ tag: filterTag, notes: results.map(r => ({ title: r.node.title, path: r.node.path })) });
      if (results.length === 0) return output(`No notes tagged "${filterTag}"`);
      const lines = results.map(r => `  ${r.node.title}`);
      output(`Notes tagged "${filterTag}":\n${lines.join('\n')}`);
      return;
    }

    const tagCounts = engine.getAllTags();

    if (jsonMode) return output({ tags: Object.fromEntries(tagCounts) });
    if (tagCounts.size === 0) return output('No tags found');
    const sorted = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]);
    const lines = sorted.map(([t, count]) => `  ${t} (${count})`);
    output(`Tags:\n${lines.join('\n')}`);
  },

  recent() {
    const limit = parseInt(commandArgs[0]) || 10;
    const engine = getEngine();
    // Use DB for titles, filesystem only for mtime
    const dbNodes = engine.graph && engine.graph._stmts
      ? engine.graph._stmts.getAllNodes.all()
      : null;
    const titleMap = new Map();
    if (dbNodes) dbNodes.forEach(n => titleMap.set(n.path, n.title));

    const notes = engine.listNotes();
    const noteStats = notes.map(notePath => {
      try {
        const stat = fs.statSync(notePath);
        const title = titleMap.get(notePath) || titleMap.get(path.relative(engine.vaultPath, notePath)) || path.basename(notePath, '.md');
        return { path: notePath, title, mtime: stat.mtimeMs };
      } catch { return null; }
    }).filter(Boolean);

    noteStats.sort((a, b) => b.mtime - a.mtime);
    const recent = noteStats.slice(0, limit);

    if (jsonMode) return output({ recent: recent.map(n => ({ title: n.title, path: n.path, mtime: n.mtime })) });
    if (recent.length === 0) return output('No notes in vault');
    const lines = recent.map((n, i) => `  ${i + 1}. ${n.title} — ${formatTimeAgo(Date.now() - n.mtime)}`);
    output(`Recent Notes:\n${lines.join('\n')}`);
  },

  // --- Content operations ---

  snippets() {
    const query = commandArgs.join(' ');
    if (!query) error('Usage: zed snippets <query>');
    const engine = getEngine();
    const results = engine.searchWithSnippets(query, { limit: 5 });
    if (jsonMode) return output({ query, results });
    if (results.length === 0) return output(`No results for "${query}"`);
    const lines = results.map((r, i) => {
      const snip = r.snippets.length > 0 ? r.snippets[0].substring(0, 120) + '...' : 'No snippet';
      return `  ${i + 1}. ${r.node.title} (${r.score.toFixed(3)})\n     ${snip}`;
    });
    output(`Snippets for "${query}":\n${lines.join('\n')}`);
  },

  daily() {
    const append = commandArgs.join(' ');
    const engine = getEngine();
    const date = new Date().toISOString().split('T')[0];
    const fileName = `sessions/${date}.md`;
    const notePath = path.join(VAULT_DIR, fileName);

    if (fs.existsSync(notePath)) {
      if (append) {
        const existing = fs.readFileSync(notePath, 'utf-8');
        const timeStamp = new Date().toLocaleTimeString('en-US', { hour12: false, hour: '2-digit', minute: '2-digit' });
        fs.writeFileSync(notePath, existing + `\n\n**${timeStamp}** — ${append}\n`, 'utf-8');
        engine.incrementalBuild();
        return output(jsonMode ? { action: 'appended', file: fileName } : `Appended to ${fileName}`);
      }
      const note = engine.readNote(notePath);
      return output(jsonMode ? { file: fileName, content: note.content } : note.content);
    }

    const content = [
      '---', `title: "Session ${date}"`, `date: ${date}`, 'type: daily',
      'tags: [session, daily]', '---', '', `# Session Notes — ${date}`, '',
      '## Work Done', append || '- _Session started_', '',
      '## Decisions Made', '', '## Patterns Learned', '', '## Next Session', '',
    ].join('\n');

    engine.writeNote(notePath, content);
    engine.incrementalBuild();
    output(jsonMode ? { action: 'created', file: fileName } : `Daily note created: ${fileName}`);
  },

  template() {
    const templateType = commandArgs[0];
    const title = commandArgs.slice(1).join(' ');
    if (!templateType || !title) error('Usage: zed template <type> <title>\nTypes: decision, architecture, postmortem, pattern, daily');

    const templateMap = {
      decision: 'decision-record.md', architecture: 'architecture-doc.md',
      postmortem: 'bug-postmortem.md', pattern: 'pattern-library.md', daily: 'daily-session.md',
    };
    const subdirMap = {
      decision: 'decisions', architecture: 'architecture', postmortem: 'decisions',
      pattern: 'patterns', daily: 'sessions',
    };

    if (!templateMap[templateType]) error(`Unknown template: ${templateType}. Use: ${Object.keys(templateMap).join(', ')}`);

    const pluginRoot = path.resolve(__dirname, '..');
    const templatePath = path.join(pluginRoot, 'templates', templateMap[templateType]);
    if (!fs.existsSync(templatePath)) error(`Template file not found: ${templateMap[templateType]}`);

    let content = fs.readFileSync(templatePath, 'utf-8');
    const date = new Date().toISOString().split('T')[0];
    const slug = title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
    content = content.replace(/\{\{TITLE\}\}/g, title).replace(/\{\{DATE\}\}/g, date);

    const fileName = `${subdirMap[templateType]}/${date}-${slug}.md`;
    const notePath = path.join(VAULT_DIR, fileName);
    const engine = getEngine();
    engine.writeNote(notePath, content);
    engine.incrementalBuild();
    output(jsonMode ? { action: 'created', template: templateType, file: fileName } : `Created ${templateType}: ${fileName}`);
  },

  // --- Maintenance ---

  backup() {
    const { execFileSync } = require('child_process');
    const outputDir = commandArgs[0] ? path.resolve(commandArgs[0]) : process.cwd();

    if (!fs.existsSync(outputDir)) error(`Output directory not found: ${outputDir}`);

    // Count notes before archiving
    const engine = getEngine();
    const notes = engine.listNotes();
    const noteCount = notes.length;

    // Generate timestamped filename
    const now = new Date();
    const ts = now.toISOString().replace(/T/, '-').replace(/:/g, '').replace(/\..+/, '').slice(0, 17);
    const fileName = `zed-vault-backup-${ts}.tar.gz`;
    const filePath = path.join(outputDir, fileName);

    // Create tar.gz of vault directory, excluding SQLite database files
    try {
      execFileSync('tar', ['-czf', filePath, '--exclude=*.db', '--exclude=*.db-journal', '--exclude=*.db-wal', '--exclude=*.db-shm', '-C', path.dirname(VAULT_DIR), path.basename(VAULT_DIR)], { stdio: 'pipe' });
    } catch (tarErr) {
      error(`Backup failed: ${tarErr.message}`);
    }

    const stat = fs.statSync(filePath);
    const sizeKB = (stat.size / 1024).toFixed(1);

    if (jsonMode) {
      return output({ action: 'backup', file: filePath, noteCount, sizeBytes: stat.size });
    }
    output(`Backup created: ${filePath} (${noteCount} notes, ${sizeKB} KB)`);
  },

  rebuild() {
    const start = Date.now();
    const engine = getEngine();
    const result = engine.rebuild();
    const elapsed = Date.now() - start;
    output(jsonMode
      ? { ...result, elapsed_ms: elapsed }
      : `Rebuilt in ${elapsed}ms — ${result.nodeCount} nodes, ${result.edgeCount} edges`
    );
  },

  import() {
    const sourceDir = commandArgs[0];
    const subdir = commandArgs[1] || 'imported';
    if (!sourceDir) error('Usage: zed import <source_dir> [subdirectory]');

    const resolvedSource = path.resolve(sourceDir);
    if (!fs.existsSync(resolvedSource)) error(`Directory not found: ${resolvedSource}`);

    const fileLayerMod = require('../core/file-layer.cjs');
    const sourceFiles = fileLayerMod.listNotes(resolvedSource);
    if (sourceFiles.length === 0) return output(jsonMode ? { imported: 0, skipped: 0 } : `No .md files in ${resolvedSource}`);

    const targetDir = path.join(VAULT_DIR, subdir);
    if (!fs.existsSync(targetDir)) fs.mkdirSync(targetDir, { recursive: true });

    let imported = 0, skipped = 0;
    const resolvedVaultDir = path.resolve(VAULT_DIR);
    for (const sourceFile of sourceFiles) {
      const relativeName = path.relative(resolvedSource, sourceFile);
      const targetFile = path.join(targetDir, relativeName);
      // Path traversal guard: ensure target stays within vault
      const resolvedTarget = path.resolve(targetFile);
      if (!resolvedTarget.startsWith(resolvedVaultDir + path.sep)) { skipped++; continue; }
      if (fs.existsSync(targetFile)) { skipped++; continue; }

      const targetParent = path.dirname(targetFile);
      if (!fs.existsSync(targetParent)) fs.mkdirSync(targetParent, { recursive: true });

      let content = fs.readFileSync(sourceFile, 'utf-8');
      const { frontmatter } = fileLayerMod.parseFrontmatter(content);
      if (Object.keys(frontmatter).length === 0) {
        const title = path.basename(sourceFile, '.md');
        const date = new Date().toISOString().split('T')[0];
        content = `---\ntitle: "${title}"\ndate: ${date}\ntype: imported\ntags: [imported]\n---\n\n${content}`;
      }
      fs.writeFileSync(targetFile, content, 'utf-8');
      imported++;
    }

    const engine = getEngine();
    engine.incrementalBuild();
    output(jsonMode ? { imported, skipped, source: resolvedSource, target: targetDir } : `Imported ${imported} files (${skipped} skipped)`);
  },

  'suggest-links'() {
    const notePath = commandArgs[0];
    const limit = parseInt(commandArgs[1]) || 10;
    const engine = getEngine();
    const allNotes = engine.listNotes();
    const noteTitles = new Map();

    for (const np of allNotes) {
      try {
        const note = engine.readNote(np);
        noteTitles.set(note.title.toLowerCase(), { path: np, title: note.title });
      } catch {}
    }

    const suggestions = [];
    const notesToCheck = notePath ? [resolveNotePath(notePath)].filter(Boolean) : allNotes;

    for (const np of notesToCheck) {
      if (suggestions.length >= limit) break;
      try {
        const note = engine.readNote(np);
        const bodyLower = note.body.toLowerCase();
        const existingLinks = new Set(note.wikilinks.map(l => l.target.toLowerCase()));
        for (const [titleLower, target] of noteTitles) {
          if (suggestions.length >= limit) break;
          if (target.path === np) continue;
          if (existingLinks.has(titleLower)) continue;
          if (bodyLower.includes(titleLower) && titleLower.length > 3) {
            suggestions.push({ from: note.title, to: target.title });
          }
        }
      } catch {}
    }

    if (jsonMode) return output({ suggestions });
    if (suggestions.length === 0) return output('No unlinked mentions found');
    const lines = suggestions.map((s, i) => `  ${i + 1}. "${s.from}" → link to "${s.to}"`);
    output(`Suggested Links:\n${lines.join('\n')}`);
  },

  timeline() {
    const typeFilter = commandArgs[0] || '';
    const validTypes = ['decision', 'daily', 'pattern', 'postmortem', 'architecture', 'note'];
    if (typeFilter && !validTypes.includes(typeFilter)) {
      error(`Invalid type "${typeFilter}". Valid types: ${validTypes.join(', ')}`);
    }
    const limit = parseInt(commandArgs[1]) || 20;
    const engine = getEngine();
    const notes = engine.listNotes();
    const entries = [];

    for (const notePath of notes) {
      try {
        const note = engine.readNote(notePath);
        const type = note.frontmatter.type || 'note';
        if (typeFilter && type !== typeFilter) continue;
        entries.push({ title: note.title, type, date: note.frontmatter.date || 'undated' });
      } catch {}
    }

    entries.sort((a, b) => {
      if (a.date === 'undated') return 1;
      if (b.date === 'undated') return -1;
      return b.date.localeCompare(a.date);
    });

    const limited = entries.slice(0, limit);
    if (jsonMode) return output({ entries: limited });
    if (limited.length === 0) return output('No entries');
    const badge = { decision: 'D', daily: 'S', pattern: 'P', postmortem: 'B', architecture: 'A', note: 'N' };
    const lines = limited.map(e => `  ${e.date} [${badge[e.type] || 'N'}] ${e.title}`);
    output(`Timeline:\n${lines.join('\n')}\n  [D]ecision [S]ession [P]attern [B]ug [A]rchitecture [N]ote`);
  },

  graph() {
    const maxNodes = parseInt(commandArgs[0]) || 50;
    const engine = getEngine();
    const stats = engine.getStats();
    const hubs = engine.findHubs(maxNodes);
    const clusters = engine.getClusters();
    const orphans = engine.getOrphans();

    const nodes = [];
    const edges = [];

    // Build a backlink count lookup from hubs for display purposes
    const backlinkMap = new Map();
    for (const hub of hubs) {
      backlinkMap.set(hub.path, hub.backlink_count);
    }

    // Include ALL vault notes, not just hubs, capped by maxNodes
    const allNotes = engine.listNotes();
    for (const notePath of allNotes.slice(0, maxNodes)) {
      try {
        const note = engine.readNote(notePath);
        nodes.push({
          id: note.id || notePath,
          title: note.title,
          type: note.type || 'note',
          backlinks: backlinkMap.get(notePath) || 0,
        });
        const outlinks = engine.getOutlinks(notePath);
        for (const link of outlinks) {
          edges.push({ from: note.title, to: link.target_title, label: link.link_text });
        }
      } catch {}
    }

    output({
      stats,
      nodes,
      edges,
      clusters: clusters.map((c, i) => ({ id: i + 1, size: c.length, members: c.map(n => n.title) })),
      orphans: orphans.map(o => o.title),
    });
  },

  promote() {
    const notePath = commandArgs[0];
    const subdir = commandArgs[1] || 'patterns';
    if (!notePath) error('Usage: zed promote <note> [subdir]');
    if (subdir) {
      const targetDirCheck = path.resolve(GLOBAL_DIR, subdir);
      if (!targetDirCheck.startsWith(path.resolve(GLOBAL_DIR))) {
        error('Subdirectory path escapes global vault');
      }
    }

    const resolved = resolveNotePath(notePath);
    if (!resolved) error(`Note not found: ${notePath}`);

    const engine = getEngine();
    const note = engine.readNote(resolved);
    const targetDir = path.join(GLOBAL_DIR, subdir);
    if (!fs.existsSync(targetDir)) fs.mkdirSync(targetDir, { recursive: true });

    const targetFile = path.join(targetDir, path.basename(resolved));
    if (fs.existsSync(targetFile)) {
      if (jsonMode) {
        output({ alreadyExists: true, file: `${subdir}/${path.basename(resolved)}` });
      } else {
        error(`Already exists in global vault: ${path.basename(resolved)}`);
      }
      return;
    }

    fs.writeFileSync(targetFile, note.content, 'utf-8');
    const globalEngine = getGlobalEngine();
    globalEngine.incrementalBuild();
    output(jsonMode
      ? { action: 'promoted', file: `${subdir}/${path.basename(resolved)}` }
      : `Promoted to global: ${subdir}/${path.basename(resolved)}`
    );
  },

  'global-search'() {
    const query = commandArgs.join(' ');
    if (!query) error('Usage: zed global-search <query>');

    const engine = getEngine();
    const globalEngine = getGlobalEngine();
    const projectResults = engine.searchNotes(query, { limit: 10 });
    const globalResults = globalEngine.searchNotes(query, { limit: 10 });

    if (jsonMode) return output({
      query,
      project: projectResults.map(r => ({ title: r.node.title, score: r.boostedScore })),
      global: globalResults.map(r => ({ title: r.node.title, score: r.boostedScore })),
    });

    const lines = [];
    if (projectResults.length > 0) {
      lines.push('Project:');
      projectResults.forEach((r, i) => lines.push(`  ${i + 1}. ${r.node.title} (${r.boostedScore.toFixed(3)})`));
    }
    if (globalResults.length > 0) {
      lines.push('Global:');
      globalResults.forEach((r, i) => lines.push(`  ${i + 1}. ${r.node.title} (${r.boostedScore.toFixed(3)})`));
    }
    if (lines.length === 0) return output(`No results for "${query}"`);
    output(lines.join('\n'));
  },

  license() {
    const action = commandArgs[0] || 'status';
    const { LicenseManager } = require('../core/license.cjs');
    const lm = new LicenseManager(DATA_DIR);

    if (action === 'activate') {
      const key = commandArgs[1];
      if (!key) error('Usage: zed license activate <key>');
      const result = lm.activate(key);
      output(jsonMode ? result : (result.success ? `License activated: ${result.message}` : `Failed: ${result.message}`));
      return;
    }

    const status = lm.getStatus();
    if (jsonMode) return output(status);
    const lines = [`Status: ${status.valid ? 'Active' : 'Inactive'}`, `Tier: ${status.tier}`];
    if (status.daysRemaining !== null) lines.push(`Days remaining: ${status.daysRemaining}`);
    output(lines.join('  |  '));
  },

  overview() {
    const engine = getEngine();
    const stats = engine.getStats();

    if (stats.nodeCount === 0) {
      return output('ZED Vault: Empty\n  Get started: zed daily, zed template decision "My First Decision"');
    }

    const allHubs = engine.findHubs(100);
    const hubs = allHubs.slice(0, 5);
    const orphans = engine.getOrphans();
    const clusters = engine.getClusters();

    // Health score (shared with health command)
    const hubsWithLinks = allHubs.filter(h => h.backlink_count > 0).length;
    const { score, grade } = computeHealthScore(stats, clusters.length, hubsWithLinks);

    if (jsonMode) return output({ stats, score, grade, hubs: hubs.map(h => h.title), orphanCount: orphans.length, clusterCount: clusters.length });

    const lines = [
      `ZED Vault Overview`,
      `  Health: ${grade} (${score}/100)  |  Notes: ${stats.nodeCount}  |  Connections: ${stats.edgeCount}  |  Orphans: ${stats.orphanCount}`,
    ];
    if (hubs.length > 0) lines.push(`  Top hubs: ${hubs.map(h => h.title).join(', ')}`);
    if (clusters.length > 1) lines.push(`  Clusters: ${clusters.length}`);
    output(lines.join('\n'));
  },

  // --- Analytics ---

  analytics() {
    const engine = getEngine();
    const stats = engine.getStats();
    const notes = engine.listNotes();
    const tags = engine.getAllTags();

    // Group notes by date and type
    const byDate = {};
    const byType = {};
    for (const notePath of notes) {
      try {
        const note = engine.readNote(notePath);
        const date = note.frontmatter?.date
          ? String(note.frontmatter.date).slice(0, 10)
          : new Date(fs.statSync(notePath).mtime).toISOString().slice(0, 10);
        byDate[date] = (byDate[date] || 0) + 1;
        const type = note.frontmatter?.type || 'note';
        byType[type] = (byType[type] || 0) + 1;
      } catch (e) { /* skip unreadable */ }
    }

    // Last 7 days
    const today = new Date();
    const recentDays = [];
    for (let i = 6; i >= 0; i--) {
      const d = new Date(today);
      d.setDate(d.getDate() - i);
      const key = d.toISOString().slice(0, 10);
      recentDays.push({ date: key, count: byDate[key] || 0 });
    }

    // Graph density
    const density = stats.nodeCount > 1
      ? (stats.edgeCount / (stats.nodeCount * (stats.nodeCount - 1))).toFixed(4)
      : 0;

    // Top 5 tags
    const topTags = [...tags.entries()]
      .sort((a, b) => b[1] - a[1])
      .slice(0, 5);

    // Health score
    const allHubs = engine.findHubs(100);
    const clusters = engine.getClusters();
    const hubsWithLinks = allHubs.filter(h => h.backlink_count > 0).length;
    const healthResult = computeHealthScore(stats, clusters.length, hubsWithLinks);

    if (jsonMode) {
      return output({
        stats,
        byType,
        recentDays,
        density: parseFloat(density),
        topTags: Object.fromEntries(topTags),
        orphanRatio: stats.nodeCount > 0 ? parseFloat((stats.orphanCount / stats.nodeCount).toFixed(2)) : 0,
        health: { score: healthResult.score, grade: healthResult.grade },
      });
    }

    console.log('ZED Vault Analytics');
    console.log(`  Total: ${stats.nodeCount} notes, ${stats.edgeCount} connections`);
    console.log(`  Health: ${healthResult.grade} (${healthResult.score}/100)`);
    console.log(`  Density: ${density} (edges per possible connection)`);
    console.log(`  Orphans: ${stats.orphanCount} (${stats.nodeCount > 0 ? Math.round(stats.orphanCount / stats.nodeCount * 100) : 0}%)`);
    console.log('');
    console.log('  By Type:');
    for (const [type, count] of Object.entries(byType).sort((a, b) => b[1] - a[1])) {
      console.log(`    ${type}: ${count}`);
    }
    console.log('');
    console.log('  Last 7 Days:');
    for (const day of recentDays) {
      const bar = '\u2588'.repeat(day.count);
      console.log(`    ${day.date}: ${bar || '\u00b7'} (${day.count})`);
    }
    console.log('');
    if (topTags.length > 0) {
      console.log('  Top Tags:');
      for (const [tag, count] of topTags) {
        console.log(`    #${tag}: ${count}`);
      }
    } else {
      console.log('  Top Tags: (none)');
    }
  },

  // --- Evolve Loop ---

  // Shared helper: validate that both loop state files exist
  // Returns { valid, objectivePath, progressPath, missing }
};

function _validateLoopState() {
  const loopDir = path.join(VAULT_DIR, '_loop');
  const objectivePath = path.join(loopDir, 'objective.md');
  const progressPath = path.join(loopDir, 'progress.md');

  const missing = [];
  if (!fs.existsSync(objectivePath)) missing.push('objective.md');
  if (!fs.existsSync(progressPath)) missing.push('progress.md');

  return {
    valid: missing.length === 0,
    loopDir,
    objectivePath,
    progressPath,
    missing,
  };
}

// Re-open commands object to add loop commands
Object.assign(commands, {

  'loop-init'() {
    const objective = commandArgs[0];
    if (!objective) error('Usage: zed loop-init "objective text" [--max N]');

    let maxIterations = 0;
    const maxIdx = commandArgs.indexOf('--max');
    if (maxIdx !== -1 && commandArgs[maxIdx + 1]) {
      maxIterations = parseInt(commandArgs[maxIdx + 1]) || 0;
    }

    const date = new Date().toISOString().split('T')[0];
    const loopDir = path.join(VAULT_DIR, '_loop');

    // Warn if a loop is already active
    const existingState = _validateLoopState();
    if (existingState.valid) {
      const existingContent = fs.readFileSync(existingState.objectivePath, 'utf-8');
      const existingTitle = (existingContent.match(/^title:\s*"(.+)"/m) || [])[1] || 'Unknown';
      if (!jsonMode) {
        console.error(`Warning: Overwriting active loop "${existingTitle}"`);
      }
    }

    const objectiveContent = [
      '---',
      `title: "${objective}"`,
      `date: ${date}`,
      'type: loop-objective',
      `max_iterations: ${maxIterations}`,
      'self_assess_every: 3',
      'completed: false',
      'tags: [loop, evolve]',
      '---',
      '',
      '# Objective',
      '',
      objective,
      '',
      '## Scope',
      '',
      '_Defined by the objective above. Stay focused._',
      '',
      '## Success Criteria',
      '',
      '_Objective is fully achieved._',
      '',
    ].join('\n');

    const progressContent = [
      '---',
      'title: "Evolve Progress"',
      `date: ${date}`,
      'type: loop-progress',
      'iteration: 0',
      'tags: [loop, evolve]',
      '---',
      '',
      '# Evolve Progress',
      '',
      '---',
      '',
    ].join('\n');

    fs.writeFileSync(path.join(loopDir, 'objective.md'), objectiveContent, 'utf-8');
    fs.writeFileSync(path.join(loopDir, 'progress.md'), progressContent, 'utf-8');

    output(jsonMode
      ? { action: 'loop-init', objective, max_iterations: maxIterations }
      : `Evolve loop initialized: "${objective}" (max: ${maxIterations === 0 ? 'unlimited' : maxIterations})`
    );
  },

  'loop-tick'() {
    const note = commandArgs[0];
    if (!note) error('Usage: zed loop-tick "what was accomplished this iteration"');

    const state = _validateLoopState();
    if (!state.valid) {
      if (state.missing.length === 2) {
        error('No active evolve loop. Start one with: zed loop-init "objective"');
      }
      error(`Loop state is corrupt: missing ${state.missing.join(', ')}. Run \`zed loop-init\` to start fresh.`);
    }

    const { loopDir, progressPath, objectivePath } = state;

    let progressContent = fs.readFileSync(progressPath, 'utf-8');

    // Parse current iteration from frontmatter only (between --- markers)
    const fmParts = progressContent.split('---');
    let currentIteration = 0;
    if (fmParts.length >= 3) {
      const frontmatter = fmParts[1];
      const iterMatch = frontmatter.match(/^iteration:\s*(\d+)/m);
      currentIteration = iterMatch ? parseInt(iterMatch[1]) : 0;
    }
    const newIteration = currentIteration + 1;

    // Update iteration in frontmatter only
    if (fmParts.length >= 3) {
      fmParts[1] = fmParts[1].replace(/^iteration:\s*\d+/m, `iteration: ${newIteration}`);
      progressContent = fmParts.join('---');
    }

    // Append new entry
    const timestamp = new Date().toISOString();
    const entry = `### Iteration ${newIteration} — ${timestamp}\n\n${note}\n\n---\n\n`;
    progressContent = progressContent + entry;

    fs.writeFileSync(progressPath, progressContent, 'utf-8');

    // Check max_iterations from objective
    let maxIterations = 0;
    let shouldContinue = true;
    if (fs.existsSync(objectivePath)) {
      const objectiveContent = fs.readFileSync(objectivePath, 'utf-8');
      const maxMatch = objectiveContent.match(/^max_iterations:\s*(\d+)/m);
      maxIterations = maxMatch ? parseInt(maxMatch[1]) : 0;
      if (maxIterations > 0 && newIteration >= maxIterations) {
        shouldContinue = false;
      }
    }

    output(jsonMode
      ? { iteration: newIteration, max: maxIterations, continue: shouldContinue }
      : `Iteration ${newIteration}/${maxIterations === 0 ? 'unlimited' : maxIterations} recorded. Continue: ${shouldContinue}`
    );
  },

  'loop-status'() {
    const state = _validateLoopState();
    if (!state.valid) {
      // If both are missing, it's simply no loop. If only one is missing, it's corrupt.
      if (state.missing.length === 2) {
        return output(jsonMode ? { active: false, message: 'No active evolve loop' } : 'No active evolve loop');
      }
      return error(`Loop state is corrupt: missing ${state.missing.join(', ')}. Run \`zed loop-init\` to start fresh.`);
    }

    const { loopDir, objectivePath, progressPath } = state;

    const objectiveContent = fs.readFileSync(objectivePath, 'utf-8');
    const progressContent = fs.readFileSync(progressPath, 'utf-8');

    // Parse objective frontmatter
    const titleMatch = objectiveContent.match(/^title:\s*"(.+)"/m);
    const maxMatch = objectiveContent.match(/^max_iterations:\s*(\d+)/m);
    const completedMatch = objectiveContent.match(/^completed:\s*(true|false)/m);

    const title = titleMatch ? titleMatch[1] : 'Unknown';
    const maxIterations = maxMatch ? parseInt(maxMatch[1]) : 0;
    const completed = completedMatch ? completedMatch[1] === 'true' : false;

    // Parse progress frontmatter
    const iterMatch = progressContent.match(/^iteration:\s*(\d+)/m);
    const iteration = iterMatch ? parseInt(iterMatch[1]) : 0;

    // Get last progress entry
    const entries = progressContent.split(/^### /m).slice(1);
    const lastEntry = entries.length > 0 ? '### ' + entries[entries.length - 1].trim() : 'No iterations yet';

    // List assessment files
    const assessments = fs.readdirSync(loopDir).filter(f => f.startsWith('assessment-') && f.endsWith('.md'));

    if (jsonMode) {
      return output({ active: true, objective: title, iteration, max: maxIterations, completed, assessments, lastEntry });
    }

    const lines = [
      `Evolve Loop Status`,
      `  Objective: ${title}`,
      `  Iteration: ${iteration}/${maxIterations === 0 ? 'unlimited' : maxIterations}`,
      `  Completed: ${completed}`,
    ];
    if (assessments.length > 0) lines.push(`  Assessments: ${assessments.join(', ')}`);
    lines.push(`  Last entry:\n    ${lastEntry.split('\n').join('\n    ')}`);
    output(lines.join('\n'));
  },

  'loop-stop'() {
    const reason = commandArgs[0];
    if (!reason) error('Usage: zed loop-stop "reason for stopping"');

    const state = _validateLoopState();
    if (!state.valid) {
      if (state.missing.length === 2) {
        error('No active evolve loop. Start one with: zed loop-init "objective"');
      }
      error(`Loop state is corrupt: missing ${state.missing.join(', ')}. Run \`zed loop-init\` to start fresh.`);
    }

    const { objectivePath } = state;

    let content = fs.readFileSync(objectivePath, 'utf-8');

    // Set completed to true in frontmatter
    content = content.replace(/^completed:\s*false/m, 'completed: true');

    // Append stop reason
    const timestamp = new Date().toISOString();
    content += `\n## Stopped\n\n**${timestamp}** — ${reason}\n`;

    fs.writeFileSync(objectivePath, content, 'utf-8');

    output(jsonMode
      ? { action: 'loop-stop', reason, timestamp }
      : `Evolve loop stopped: ${reason}`
    );
  },

  'loop-promote'() {
    const loopDir = path.join(VAULT_DIR, '_loop');
    const progressPath = path.join(loopDir, 'progress.md');
    const objectivePath = path.join(loopDir, 'objective.md');

    if (!fs.existsSync(progressPath)) error('No active evolve loop to promote');

    const progressContent = fs.readFileSync(progressPath, 'utf-8');
    const objectiveContent = fs.existsSync(objectivePath) ? fs.readFileSync(objectivePath, 'utf-8') : '';

    // Parse objective title
    const titleMatch = objectiveContent.match(/^title:\s*"(.+)"/m);
    const objective = titleMatch ? titleMatch[1] : 'Evolve Loop';

    // Create summary note in sessions/
    const date = new Date().toISOString().split('T')[0];
    const slug = objective.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
    const summaryFileName = `${date}-loop-${slug}.md`;
    const summaryPath = path.join(VAULT_DIR, 'sessions', summaryFileName);

    const summaryContent = [
      '---',
      `title: "Loop Summary: ${objective}"`,
      `date: ${date}`,
      'type: loop-summary',
      'tags: [loop, evolve, summary]',
      '---',
      '',
      `# Loop Summary: ${objective}`,
      '',
      '## Objective',
      '',
      objective,
      '',
      '## Progress Log',
      '',
      progressContent.split('---').slice(2).join('---').trim(),
      '',
    ].join('\n');

    fs.writeFileSync(summaryPath, summaryContent, 'utf-8');
    const promoted = [summaryFileName];

    // Move assessment files to sessions/
    const loopFiles = fs.readdirSync(loopDir);
    const assessments = loopFiles.filter(f => f.startsWith('assessment-') && f.endsWith('.md'));
    for (const assessment of assessments) {
      const src = path.join(loopDir, assessment);
      const dest = path.join(VAULT_DIR, 'sessions', assessment);
      fs.copyFileSync(src, dest);
      promoted.push(assessment);
    }

    // Clear _loop/ directory (handles both files and subdirectories)
    for (const file of loopFiles) {
      fs.rmSync(path.join(loopDir, file), { recursive: true, force: true });
    }

    // Rebuild graph
    const engine = getEngine();
    engine.incrementalBuild();

    output(jsonMode
      ? { action: 'loop-promote', promoted }
      : `Promoted ${promoted.length} file(s) to sessions/:\n${promoted.map(f => '  ' + f).join('\n')}`
    );
  },

  'loop-decompose'() {
    const loopDir = path.join(VAULT_DIR, '_loop');
    const objectivePath = path.join(loopDir, 'objective.md');
    const featuresPath = path.join(loopDir, 'features.json');

    if (!fs.existsSync(objectivePath)) {
      error('No active evolve loop. Start one with: zed loop-init "objective"');
    }

    // Read features from stdin or command args
    const input = commandArgs.join(' ');
    if (!input) {
      // If no input, show current features
      if (fs.existsSync(featuresPath)) {
        const features = JSON.parse(fs.readFileSync(featuresPath, 'utf8'));
        if (jsonMode) {
          console.log(JSON.stringify(features, null, 2));
        } else {
          console.log('Evolve Loop Features:');
          features.forEach((f, i) => {
            const status = f.status === 'done' ? '\u2713' : f.status === 'in_progress' ? '\u2192' : ' ';
            console.log(`  [${status}] ${i + 1}. ${f.description} (${f.status}, ${f.attempts}/${f.max_attempts} attempts)`);
          });
        }
      } else {
        console.log('No features.json found. Provide features as comma-separated list:');
        console.log('  zed loop-decompose "feature1, feature2, feature3"');
      }
      return;
    }

    // Parse comma-separated features
    const featureList = input.split(',').map(f => f.trim()).filter(f => f.length > 0);

    const features = featureList.map((desc, i) => ({
      id: i + 1,
      description: desc,
      status: 'pending',      // pending, in_progress, done, blocked
      attempts: 0,
      max_attempts: 5,
      priority: i + 1,
      verification: null,     // command to verify completion
      completed_at: null,
      wall_log: []            // obstacles encountered
    }));

    fs.writeFileSync(featuresPath, JSON.stringify(features, null, 2));

    if (jsonMode) {
      console.log(JSON.stringify({ action: 'decomposed', count: features.length, features }));
    } else {
      console.log(`Decomposed into ${features.length} features:`);
      features.forEach((f, i) => {
        console.log(`  ${i + 1}. ${f.description}`);
      });
    }
  },

  'loop-next'() {
    const featuresPath = path.join(VAULT_DIR, '_loop', 'features.json');
    if (!fs.existsSync(featuresPath)) {
      if (jsonMode) console.log(JSON.stringify({ next: null, reason: 'no features.json' }));
      else console.log('No features.json. Run: zed loop-decompose "feature1, feature2"');
      return;
    }

    const features = JSON.parse(fs.readFileSync(featuresPath, 'utf8'));
    const next = features.find(f => f.status === 'pending' || f.status === 'in_progress');

    if (!next) {
      if (jsonMode) console.log(JSON.stringify({ next: null, reason: 'all features complete' }));
      else console.log('All features complete!');
      return;
    }

    // Mark as in_progress
    next.status = 'in_progress';
    next.attempts++;
    fs.writeFileSync(featuresPath, JSON.stringify(features, null, 2));

    if (jsonMode) {
      console.log(JSON.stringify({ next }));
    } else {
      console.log(`Next feature (#${next.id}): ${next.description}`);
      console.log(`  Attempt ${next.attempts}/${next.max_attempts}`);
    }
  },

  'loop-complete'() {
    const featuresPath = path.join(VAULT_DIR, '_loop', 'features.json');
    if (!fs.existsSync(featuresPath)) {
      error('No features found. Run: zed loop-decompose "feature1, feature2" first');
    }

    const features = JSON.parse(fs.readFileSync(featuresPath, 'utf8'));
    const current = features.find(f => f.status === 'in_progress');

    if (!current) {
      error('No feature currently in progress. Run: zed loop-next to start one');
    }

    current.status = 'done';
    current.completed_at = new Date().toISOString();
    fs.writeFileSync(featuresPath, JSON.stringify(features, null, 2));

    const remaining = features.filter(f => f.status !== 'done').length;

    if (jsonMode) {
      console.log(JSON.stringify({ completed: current, remaining }));
    } else {
      console.log(`Completed: ${current.description}`);
      console.log(`${remaining} features remaining`);
    }
  },

  // --- Auto-fix ---

  fix() {
    const engine = getEngine();
    const stats = engine.getStats();

    if (stats.nodeCount === 0) {
      return output(jsonMode ? { fixed: [], score: { before: 0, after: 0 } } : 'Nothing to fix: vault is empty');
    }

    // Compute before-score
    const hubsBefore = engine.findHubs(100);
    const clustersBefore = engine.getClusters();
    const hubsWithLinksBefore = hubsBefore.filter(h => h.backlink_count > 0).length;
    const scoreBefore = computeHealthScore(stats, clustersBefore.length, hubsWithLinksBefore);

    const fixed = [];

    // --- Fix 1: Missing tags — add "untagged" to notes without tags ---
    const allNotes = engine.listNotes();
    for (const notePath of allNotes) {
      try {
        const note = engine.readNote(notePath);
        const tags = note.frontmatter.tags;
        const hasTags = Array.isArray(tags) ? tags.length > 0 : (typeof tags === 'string' && tags.length > 0);

        if (!hasTags) {
          let content = note.content;
          if (content.match(/^---\r?\n[\s\S]*?\r?\n---/)) {
            // Has frontmatter — insert tags line before closing ---
            content = content.replace(/\n---(\r?\n)/, '\ntags: [untagged]\n---$1');
          } else {
            // No frontmatter at all — prepend minimal frontmatter
            const title = note.title || path.basename(notePath, '.md');
            content = `---\ntitle: "${title}"\ntags: [untagged]\n---\n\n${content}`;
          }
          fs.writeFileSync(notePath, content, 'utf-8');
          fixed.push({ type: 'missing-tags', note: path.basename(notePath, '.md'), action: 'added tag "untagged"' });
        }
      } catch { /* skip unreadable notes */ }
    }

    // --- Fix 2: Broken wikilinks — create stub notes for missing targets ---
    const allNotePaths = new Set(allNotes.map(p => path.resolve(p)));
    const allTitles = new Map();
    for (const np of allNotes) {
      try {
        const note = engine.readNote(np);
        allTitles.set(note.title.toLowerCase(), np);
      } catch {}
    }

    const stubsCreated = new Set();
    for (const notePath of allNotes) {
      try {
        const note = engine.readNote(notePath);
        for (const link of note.wikilinks) {
          const target = link.target;
          // Strip heading/block refs for resolution
          const cleanTarget = target.split('#')[0].split('^')[0].trim();
          if (!cleanTarget) continue;

          // Check if target exists by title or filename
          const targetLower = cleanTarget.toLowerCase();
          if (allTitles.has(targetLower)) continue;

          // Check by filename
          const possiblePath = path.join(VAULT_DIR, cleanTarget + '.md');
          const possiblePathResolved = path.resolve(possiblePath);
          if (allNotePaths.has(possiblePathResolved)) continue;

          // Also check subdirectories
          let found = false;
          for (const np of allNotes) {
            const basename = path.basename(np, '.md').toLowerCase();
            if (basename === targetLower) { found = true; break; }
          }
          if (found) continue;

          // Target does not exist — create stub (avoid duplicates)
          if (stubsCreated.has(targetLower)) continue;
          stubsCreated.add(targetLower);

          const stubPath = path.join(VAULT_DIR, cleanTarget.replace(/[/\\]/g, '-') + '.md');
          // Only create if inside vault (safety check)
          const resolvedStub = path.resolve(stubPath);
          if (!resolvedStub.startsWith(path.resolve(VAULT_DIR) + path.sep)) continue;

          if (!fs.existsSync(stubPath)) {
            const date = new Date().toISOString().split('T')[0];
            const stubContent = [
              '---',
              `title: "${cleanTarget}"`,
              `date: ${date}`,
              'type: stub',
              'tags: [stub]',
              '---',
              '',
              `# ${cleanTarget}`,
              '',
              '_Stub note created by `zed fix`. Add content here._',
              '',
            ].join('\n');
            fs.writeFileSync(stubPath, stubContent, 'utf-8');
            fixed.push({ type: 'broken-wikilink', note: cleanTarget, action: 'created stub note' });
          }
        }
      } catch { /* skip unreadable notes */ }
    }

    // --- Fix 3: Orphan notes — add backlink index entry ---
    // Re-read after stubs may have been created
    engine.rebuild();
    const orphans = engine.getOrphans();
    if (orphans.length > 0) {
      const date = new Date().toISOString().split('T')[0];
      const indexPath = path.join(VAULT_DIR, `_index-${date}.md`);
      const orphanLinks = orphans.map(o => `- [[${o.title}]]`);
      const indexContent = [
        '---',
        `title: "Index ${date}"`,
        `date: ${date}`,
        'type: index',
        'tags: [index, auto-generated]',
        '---',
        '',
        `# Daily Index — ${date}`,
        '',
        'Notes connected by `zed fix`:',
        '',
        ...orphanLinks,
        '',
      ].join('\n');
      fs.writeFileSync(indexPath, indexContent, 'utf-8');
      for (const o of orphans) {
        fixed.push({ type: 'orphan-note', note: o.title, action: `linked from index ${date}` });
      }
    }

    // Rebuild graph after all fixes and compute after-score
    engine.rebuild();
    const statsAfter = engine.getStats();
    const hubsAfter = engine.findHubs(100);
    const clustersAfter = engine.getClusters();
    const hubsWithLinksAfter = hubsAfter.filter(h => h.backlink_count > 0).length;
    const scoreAfter = computeHealthScore(statsAfter, clustersAfter.length, hubsWithLinksAfter);

    if (jsonMode) {
      return output({
        fixed,
        score: { before: scoreBefore.score, after: scoreAfter.score },
      });
    }

    if (fixed.length === 0) {
      return output(`No issues to fix. Health: ${scoreBefore.grade} (${scoreBefore.score}/100)`);
    }

    const lines = [
      `Fixed ${fixed.length} issue(s):`,
    ];
    for (const f of fixed) {
      lines.push(`  [${f.type}] ${f.note} — ${f.action}`);
    }
    lines.push('');
    lines.push(`Health: ${scoreBefore.grade} (${scoreBefore.score}/100) -> ${scoreAfter.grade} (${scoreAfter.score}/100)`);
    output(lines.join('\n'));
  },

  // --- Visualize (Excalidraw graph) ---

  visualize() {
    const engine = getEngine();
    const allNotes = engine.listNotes();

    if (allNotes.length === 0) {
      return output(jsonMode
        ? { action: 'visualize', nodeCount: 0, edgeCount: 0, message: 'Nothing to visualize — vault is empty' }
        : 'Nothing to visualize — vault is empty. Add notes first.'
      );
    }

    const stats = engine.getStats();
    const hubs = engine.findHubs(allNotes.length || 50);

    // Build backlink count lookup
    const backlinkMap = new Map();
    for (const hub of hubs) {
      backlinkMap.set(hub.path, hub.backlink_count);
    }

    // Collect all nodes with metadata
    const noteNodes = [];
    const edgeList = [];

    for (const notePath of allNotes) {
      try {
        const note = engine.readNote(notePath);
        const type = (note.type || 'note').toLowerCase();
        const backlinkCount = backlinkMap.get(notePath) || 0;
        noteNodes.push({
          id: note.id || notePath,
          title: note.title || path.basename(notePath, '.md'),
          type,
          backlinkCount,
          path: notePath,
        });
        const outlinks = engine.getOutlinks(notePath);
        for (const link of outlinks) {
          edgeList.push({
            sourceTitle: note.title || path.basename(notePath, '.md'),
            targetTitle: link.target_title,
          });
        }
      } catch {}
    }

    // --- Color mapping by type ---
    const typeColors = {
      decision: '#a5d8ff',   // blue
      pattern:  '#b2f2bb',   // green
      project:  '#d0bfff',   // purple
      session:  '#dee2e6',   // gray
    };
    const defaultColor = '#ffffff'; // white

    // --- Group by type for grid layout ---
    const typeGroups = {};
    for (const node of noteNodes) {
      if (!typeGroups[node.type]) typeGroups[node.type] = [];
      typeGroups[node.type].push(node);
    }

    // Sort each group by backlink count descending
    for (const type of Object.keys(typeGroups)) {
      typeGroups[type].sort((a, b) => b.backlinkCount - a.backlinkCount);
    }

    // Assign grid positions: each type gets a column, nodes arranged vertically
    const typeOrder = Object.keys(typeGroups).sort();
    const SPACING_X = 300;
    const SPACING_Y = 200;
    const BASE_WIDTH = 180;
    const BASE_HEIGHT = 50;

    const elements = [];
    const nodePositions = new Map(); // title -> { x, y, width, height, elementId }

    let colIndex = 0;
    for (const type of typeOrder) {
      const group = typeGroups[type];
      let rowIndex = 0;
      for (const node of group) {
        // Size by backlink count
        const scale = 1 + Math.min(node.backlinkCount, 10) * 0.1;
        const w = Math.round(BASE_WIDTH * scale);
        const h = Math.round(BASE_HEIGHT * scale);
        const x = 100 + colIndex * SPACING_X;
        const y = 100 + rowIndex * SPACING_Y;

        const rectId = `rect-${node.id}`.replace(/[^a-zA-Z0-9-_]/g, '_');
        const textId = `text-${node.id}`.replace(/[^a-zA-Z0-9-_]/g, '_');
        const bgColor = typeColors[node.type] || defaultColor;

        // Rectangle element
        elements.push({
          type: 'rectangle',
          id: rectId,
          x,
          y,
          width: w,
          height: h,
          strokeColor: '#1e1e1e',
          backgroundColor: bgColor,
          fillStyle: 'solid',
          strokeWidth: 1,
          roundness: { type: 3 },
          boundElements: [{ id: textId, type: 'text' }],
        });

        // Text element bound to rectangle
        elements.push({
          type: 'text',
          id: textId,
          x: x + 10,
          y: y + h / 2 - 10,
          width: w - 20,
          height: 20,
          text: node.title,
          fontSize: 14,
          fontFamily: 1,
          textAlign: 'center',
          verticalAlign: 'middle',
          containerId: rectId,
        });

        nodePositions.set(node.title, { x, y, width: w, height: h, elementId: rectId });
        rowIndex++;
      }
      colIndex++;
    }

    // --- Arrows for edges ---
    let arrowIndex = 0;
    for (const edge of edgeList) {
      const src = nodePositions.get(edge.sourceTitle);
      const tgt = nodePositions.get(edge.targetTitle);
      if (!src || !tgt) continue;

      const arrowId = `arrow-${arrowIndex++}`;
      elements.push({
        type: 'arrow',
        id: arrowId,
        x: src.x + src.width,
        y: src.y + src.height / 2,
        width: tgt.x - (src.x + src.width),
        height: tgt.y + tgt.height / 2 - (src.y + src.height / 2),
        strokeColor: '#868e96',
        strokeWidth: 1,
        startBinding: { elementId: src.elementId, focus: 0, gap: 4 },
        endBinding: { elementId: tgt.elementId, focus: 0, gap: 4 },
        points: [
          [0, 0],
          [tgt.x - (src.x + src.width), tgt.y + tgt.height / 2 - (src.y + src.height / 2)],
        ],
      });
    }

    // Build Excalidraw file structure
    const excalidrawData = {
      type: 'excalidraw',
      version: 2,
      source: 'zed-knowledge-engine',
      elements,
      appState: {
        viewBackgroundColor: '#ffffff',
        gridSize: null,
      },
      files: {},
    };

    // Handle --out flag
    const outIndex = commandArgs.indexOf('--out');
    if (outIndex !== -1 && commandArgs[outIndex + 1]) {
      const outFile = commandArgs[outIndex + 1];
      fs.writeFileSync(outFile, JSON.stringify(excalidrawData, null, 2), 'utf-8');
      if (jsonMode) {
        output({ action: 'visualize', file: outFile, nodeCount: noteNodes.length, edgeCount: edgeList.length });
      } else {
        output(`Excalidraw graph written to ${outFile} (${noteNodes.length} nodes, ${edgeList.length} edges)`);
      }
    } else {
      // Launch interactive graph in browser
      const os = require('os');
      const { spawn } = require('child_process');
      const tmpFile = path.join(os.tmpdir(), `zed-graph-${Date.now()}.json`);
      fs.writeFileSync(tmpFile, JSON.stringify(excalidrawData, null, 2), 'utf-8');

      const serverScript = path.join(__dirname, '..', 'scripts', 'graph-server.cjs');
      const child = spawn(process.execPath, [serverScript, tmpFile], {
        detached: true,
        stdio: 'inherit',
      });
      child.unref();

      if (jsonMode) {
        output({ action: 'visualize', mode: 'browser', nodeCount: noteNodes.length, edgeCount: edgeList.length });
      }
    }
  },
});

// ---------------------------------------------------------------------------
// Scan command — learn an existing codebase and populate the knowledge graph
// ---------------------------------------------------------------------------

Object.assign(commands, {
  scan() {
    const targetDir = commandArgs[0] ? path.resolve(commandArgs[0]) : process.cwd();

    if (!fs.existsSync(targetDir) || !fs.statSync(targetDir).isDirectory()) {
      error(`Directory not found: ${targetDir}`);
    }

    // --- Determine project name ---
    const pkgPath = path.join(targetDir, 'package.json');
    let pkg = null;
    let projectName;
    if (fs.existsSync(pkgPath)) {
      try { pkg = JSON.parse(fs.readFileSync(pkgPath, 'utf-8')); } catch {}
    }
    projectName = (pkg && pkg.name) ? pkg.name : path.basename(targetDir);
    // Sanitize for filenames
    const safeName = projectName.replace(/[^a-zA-Z0-9_-]/g, '-').replace(/--+/g, '-');

    // --- Read README (first 50 lines) ---
    let readmeSnippet = '';
    const readmePath = path.join(targetDir, 'README.md');
    if (fs.existsSync(readmePath)) {
      try {
        const lines = fs.readFileSync(readmePath, 'utf-8').split('\n').slice(0, 50);
        readmeSnippet = lines.join('\n');
      } catch {}
    }

    // --- Scan directory tree (top 2 levels) ---
    const SKIP_DIRS = new Set([
      'node_modules', '.git', 'dist', 'build', '.next', '.nuxt', '__pycache__',
      '.cache', 'coverage', '.vscode', '.idea', '.DS_Store', '.env', 'vendor',
      'tmp', 'temp', '.turbo', '.output', '.svelte-kit',
    ]);

    function scanDir(dir, depth) {
      if (depth > 2) return [];
      let entries;
      try { entries = fs.readdirSync(dir, { withFileTypes: true }); } catch { return []; }
      const result = [];
      for (const entry of entries) {
        if (SKIP_DIRS.has(entry.name) || entry.name.startsWith('.')) continue;
        const fullPath = path.join(dir, entry.name);
        const isDir = entry.isDirectory();
        const rel = path.relative(targetDir, fullPath);
        result.push({ name: entry.name, rel, isDir });
        if (isDir && depth < 2) {
          const children = scanDir(fullPath, depth + 1);
          result.push(...children);
        }
      }
      return result;
    }

    const tree = scanDir(targetDir, 0);

    // --- Detect tech stack from package.json ---
    const depCategories = {
      framework: ['react', 'next', 'vue', 'nuxt', 'angular', 'svelte', 'express', 'fastify', 'koa', 'hono', 'remix', 'gatsby', 'astro'],
      database: ['better-sqlite3', 'sqlite3', 'pg', 'mysql2', 'mongoose', 'prisma', 'drizzle-orm', 'sequelize', 'typeorm', 'knex', 'redis', 'ioredis'],
      testing: ['jest', 'vitest', 'mocha', 'chai', 'ava', 'tap', 'playwright', 'cypress', 'puppeteer', '@testing-library'],
      types: ['typescript', 'zod', 'joi', 'yup', 'ajv', '@types/node'],
      tooling: ['eslint', 'prettier', 'webpack', 'vite', 'rollup', 'esbuild', 'turbo', 'nx', 'tsup', 'babel'],
      api: ['axios', 'node-fetch', 'got', 'superagent', 'graphql', '@apollo', 'trpc'],
      auth: ['passport', 'jsonwebtoken', 'bcrypt', 'next-auth', 'clerk', 'lucia'],
      ui: ['tailwindcss', 'styled-components', '@emotion', 'sass', 'less', 'radix-ui', 'shadcn', 'mui', 'chakra-ui'],
    };

    function categorizeDep(depName) {
      for (const [cat, patterns] of Object.entries(depCategories)) {
        for (const p of patterns) {
          if (depName === p || depName.startsWith(p + '/') || depName.startsWith('@' + p)) return cat;
        }
      }
      return 'other';
    }

    const allDeps = {};
    if (pkg) {
      const merged = { ...(pkg.dependencies || {}), ...(pkg.devDependencies || {}) };
      for (const [name, version] of Object.entries(merged)) {
        const cat = categorizeDep(name);
        if (!allDeps[cat]) allDeps[cat] = [];
        allDeps[cat].push({ name, version });
      }
    }

    // --- Detect tech from file extensions ---
    const extensions = new Set();
    for (const entry of tree) {
      if (!entry.isDir) {
        const ext = path.extname(entry.name).toLowerCase();
        if (ext) extensions.add(ext);
      }
    }

    // --- Identify code directories (modules) ---
    const CODE_DIR_HINTS = new Set([
      'src', 'lib', 'api', 'components', 'pages', 'app', 'routes', 'controllers',
      'models', 'services', 'utils', 'helpers', 'hooks', 'middleware', 'config',
      'core', 'modules', 'features', 'views', 'layouts', 'stores', 'plugins',
      'commands', 'handlers', 'resolvers', 'schemas', 'types', 'interfaces',
      'tests', 'test', '__tests__', 'specs', 'e2e', 'scripts', 'bin',
      'server', 'client', 'shared', 'common', 'assets', 'public', 'static',
      'agents', 'skills', 'templates', 'cli',
    ]);

    const topLevelDirs = tree.filter(e => e.isDir && !e.rel.includes(path.sep));
    const codeDirs = topLevelDirs.filter(e => CODE_DIR_HINTS.has(e.name.toLowerCase()));

    // Cap at 20 modules
    const moduleEntries = codeDirs.slice(0, 20);

    // --- Ensure vault/projects dir ---
    const projectsDir = path.join(VAULT_DIR, 'projects');
    if (!fs.existsSync(projectsDir)) fs.mkdirSync(projectsDir, { recursive: true });

    // --- Build note filenames ---
    const archFile = `${safeName}-architecture.md`;
    const techFile = `${safeName}-tech-stack.md`;
    const moduleFiles = moduleEntries.map(m => ({
      dir: m,
      file: `${safeName}-module-${m.name.toLowerCase()}.md`,
    }));

    const allNoteNames = [
      archFile.replace('.md', ''),
      techFile.replace('.md', ''),
      ...moduleFiles.map(m => m.file.replace('.md', '')),
    ];

    const generatedNotes = [];

    // --- Helper: build note title from filename ---
    function noteTitle(filename) {
      return filename.replace('.md', '').replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
    }

    // --- 1. Architecture Overview note ---
    const archTitle = noteTitle(archFile);
    const techTitle = noteTitle(techFile);

    // Directory tree (top 2 levels)
    const treeLines = [];
    for (const e of tree) {
      if (!e.rel.includes(path.sep)) {
        treeLines.push(e.isDir ? `${e.rel}/` : e.rel);
      } else {
        const depth = e.rel.split(path.sep).length - 1;
        const indent = '  '.repeat(depth);
        treeLines.push(`${indent}${e.isDir ? e.rel.split(path.sep).pop() + '/' : e.rel.split(path.sep).pop()}`);
      }
    }

    // Key entry points
    const entryPoints = [];
    if (pkg && pkg.main) entryPoints.push(pkg.main);
    if (pkg && pkg.bin) {
      if (typeof pkg.bin === 'string') entryPoints.push(pkg.bin);
      else Object.values(pkg.bin).forEach(v => entryPoints.push(v));
    }
    if (pkg && pkg.scripts && pkg.scripts.start) entryPoints.push(`npm start -> ${pkg.scripts.start}`);

    // Tech stack summary
    const techSummary = [];
    if (extensions.has('.ts') || extensions.has('.tsx')) techSummary.push('TypeScript');
    if (extensions.has('.js') || extensions.has('.jsx') || extensions.has('.mjs') || extensions.has('.cjs')) techSummary.push('JavaScript');
    if (extensions.has('.py')) techSummary.push('Python');
    if (extensions.has('.go')) techSummary.push('Go');
    if (extensions.has('.rs')) techSummary.push('Rust');
    if (extensions.has('.java')) techSummary.push('Java');
    if (extensions.has('.rb')) techSummary.push('Ruby');
    if (pkg) techSummary.push('Node.js');

    // Module wikilinks
    const moduleWikilinks = moduleFiles.map(m => `- [[${m.file.replace('.md', '')}]]`).join('\n');

    const archContent = `---
title: "${archTitle}"
date: ${new Date().toISOString().split('T')[0]}
type: architecture
tags: [architecture, ${projectName}]
---

# ${archTitle}

## Tech Stack
${techSummary.join(', ') || 'Unknown'}

See [[${techFile.replace('.md', '')}]] for full dependency details.

## Directory Structure
\`\`\`
${treeLines.join('\n')}
\`\`\`

## Key Entry Points
${entryPoints.length > 0 ? entryPoints.map(e => `- \`${e}\``).join('\n') : '- (none detected)'}

${readmeSnippet ? `## README Excerpt\n${readmeSnippet.slice(0, 500)}\n` : ''}
## Modules
${moduleWikilinks || '(no code directories detected)'}
`;

    fs.writeFileSync(path.join(projectsDir, archFile), archContent, 'utf-8');
    generatedNotes.push({ file: `projects/${archFile}`, type: 'architecture' });

    // --- 2. Tech Stack note ---
    const depSections = [];
    for (const [cat, deps] of Object.entries(allDeps)) {
      depSections.push(`### ${cat.charAt(0).toUpperCase() + cat.slice(1)}`);
      for (const d of deps) {
        depSections.push(`- ${d.name}: ${d.version}`);
      }
      depSections.push('');
    }

    const techContent = `---
title: "${techTitle}"
date: ${new Date().toISOString().split('T')[0]}
type: tech-stack
tags: [tech-stack, ${projectName}]
---

# ${techTitle}

See [[${archFile.replace('.md', '')}]] for architecture overview.

## Languages
${techSummary.join(', ') || 'Unknown'}

## File Extensions
${[...extensions].sort().join(', ') || 'None detected'}

## Dependencies
${depSections.length > 0 ? depSections.join('\n') : '(no package.json found)'}
`;

    fs.writeFileSync(path.join(projectsDir, techFile), techContent, 'utf-8');
    generatedNotes.push({ file: `projects/${techFile}`, type: 'tech-stack' });

    // --- 3. Module notes ---
    for (const mod of moduleFiles) {
      const modDir = path.join(targetDir, mod.dir.name);
      let fileCount = 0;
      let modFiles = [];
      try {
        const entries = fs.readdirSync(modDir, { withFileTypes: true });
        for (const e of entries) {
          if (e.isFile()) {
            fileCount++;
            modFiles.push(e.name);
          } else if (e.isDirectory() && !SKIP_DIRS.has(e.name)) {
            fileCount++; // count subdirs as 1
            modFiles.push(e.name + '/');
          }
        }
      } catch {}

      // Related module wikilinks (other modules)
      const relatedModules = moduleFiles
        .filter(m => m.file !== mod.file)
        .map(m => `- [[${m.file.replace('.md', '')}]]`)
        .join('\n');

      const modTitle = noteTitle(mod.file);
      const modContent = `---
title: "${modTitle}"
date: ${new Date().toISOString().split('T')[0]}
type: module
tags: [module, ${projectName}]
---

# ${modTitle}

Part of [[${archFile.replace('.md', '')}]].

## Overview
- Directory: \`${mod.dir.name}/\`
- Files: ${fileCount}

## Key Files
${modFiles.slice(0, 15).map(f => `- \`${f}\``).join('\n') || '(empty)'}

## Related Modules
${relatedModules || '(none)'}

## Tech Stack
See [[${techFile.replace('.md', '')}]] for dependencies.
`;

      fs.writeFileSync(path.join(projectsDir, mod.file), modContent, 'utf-8');
      generatedNotes.push({ file: `projects/${mod.file}`, type: 'module' });
    }

    // --- 4. Rebuild graph ---
    const engine = getEngine();
    const rebuildResult = engine.rebuild();

    // --- Output ---
    if (jsonMode) {
      return output({
        action: 'scan',
        project: projectName,
        directory: targetDir,
        notes: generatedNotes,
        noteCount: generatedNotes.length,
        graphNodes: rebuildResult.nodeCount,
        graphEdges: rebuildResult.edgeCount,
      });
    }

    const lines = [`Scanned: ${targetDir}`, `Project: ${projectName}`, ''];
    lines.push(`Generated ${generatedNotes.length} notes:`);
    for (const n of generatedNotes) {
      lines.push(`  [${n.type}] ${n.file}`);
    }
    lines.push('');
    lines.push(`Graph rebuilt: ${rebuildResult.nodeCount} nodes, ${rebuildResult.edgeCount} edges`);
    output(lines.join('\n'));
  },
});

// ---------------------------------------------------------------------------
// Dispatch
// ---------------------------------------------------------------------------

const handler = commands[command];
if (!handler) {
  console.error(`Unknown command: ${command}`);
  printHelp();
  process.exit(1);
}

try {
  handler();
} catch (err) {
  error(err.message);
} finally {
  // Clean up
  try { if (_engine) _engine.close(); } catch {}
  try { if (_globalEngine) _globalEngine.close(); } catch {}
}

// ---------------------------------------------------------------------------
// Help
// ---------------------------------------------------------------------------

function printHelp() {
  console.log(`
ZED Knowledge Engine CLI

Usage: zed <command> [args] [--json]

Graph:
  backlinks <note>          What links to this note
  related <note> [hops]     Related notes within N hops (default: 2)
  hubs [limit]              Most-connected nodes (default: 10)
  clusters                  Knowledge clusters
  path <from> <to>          Shortest path between notes

Info:
  stats                     Vault statistics
  health                    Vault quality score
  tags [tag]                List tags or browse by tag
  recent [limit]            Recently modified notes
  overview                  Full dashboard
  timeline [type] [limit]   Chronological view
  analytics                 Knowledge growth tracking over time
  visualize [--out file]    Open interactive graph in browser (or write Excalidraw JSON with --out)

Content:
  daily [text]              Daily session note (create/append/read)
  template <type> <title>   Create from template
  snippets <query>          Search with context snippets
  suggest-links [note]      Find unlinked mentions

Maintenance:
  fix                       Auto-fix vault health issues
  backup [dir]              Create timestamped vault backup (.tar.gz)
  rebuild                   Rebuild graph index
  scan [dir]                Scan codebase, generate linked knowledge notes
  import <dir> [subdir]     Import markdown files
  promote <note> [subdir]   Promote to global vault
  global-search <query>     Search project + global vaults
  license [status|activate] License management
  graph [max_nodes]         Export graph data as JSON

Evolve Loop:
  loop-init "obj" [--max N]   Start an evolve loop
  loop-tick "progress"        Record iteration progress
  loop-status                 Check loop state
  loop-decompose "f1, f2"    Decompose objective into features
  loop-next                  Get next pending feature
  loop-complete              Mark current feature as done
  loop-stop "reason"          Stop loop gracefully
  loop-promote                Promote findings to vault

Other:
  version                   Show ZED version

Options:
  --json                    Output as JSON (for machine parsing)
  --help                    Show this help
`);
}
